# Copy this file to .env.local (never commit .env.local — it's gitignored).
# Set the same keys in Vercel → Project Settings → Environment Variables.

# Google Apps Script webhook URL for completion tracking.
# Leave blank to disable webhook calls (the app will still work normally).
VITE_WEBHOOK_URL=

# Optional: override the default demo account passwords.
# If not set, the app falls back to 'demo123' / 'alex123'.
VITE_DEMO_PASSWORD=
VITE_ALEX_PASSWORD=
